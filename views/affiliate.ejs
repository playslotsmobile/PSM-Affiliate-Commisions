<%- include('layout', { body: `
<div class="flex-between mb-4">
  <h1 style="font-size:22px; color:#7B4FFF;">${affiliate.username}</h1>
  <a href="/report/new?affiliate_id=${affiliate.id}" class="btn btn-gold">+ New Report</a>
</div>

<div class="grid-2">
  <div class="card">
    <h2>Affiliate Details</h2>
    <form method="POST" action="/affiliate/${affiliate.id}/update">
      <div class="form-group">
        <label>Email</label>
        <input type="email" name="email" value="${affiliate.email || ''}">
      </div>
      <div class="form-group">
        <label>Telegram Chat ID</label>
        <input type="text" name="telegram_chat_id" value="${affiliate.telegram_chat_id || ''}" placeholder="Auto-captured when they message the bot">
      </div>
      <div class="form-group">
        <label>Commission Rate Override (%)</label>
        <input type="number" name="commission_rate_override" step="1" min="0" max="100" value="${affiliate.commission_rate_override ? Math.round(affiliate.commission_rate_override * 100) : ''}" placeholder="Leave blank for tier-based">
      </div>
      <div class="form-group">
        <label>Notes</label>
        <textarea name="notes" rows="2">${affiliate.notes || ''}</textarea>
      </div>
      <button type="submit" class="btn btn-outline btn-sm">Update</button>
    </form>
  </div>

  <div class="card">
    <h2>Player Average (Last 12 Weeks)</h2>
    ${playerHistory.length === 0 ? '<p class="text-gray">No player data yet.</p>' : `
      <table>
        <thead><tr><th>Week</th><th>Players</th></tr></thead>
        <tbody>
          ${playerHistory.map(p => `<tr><td>${p.week_start}</td><td>${p.player_count}</td></tr>`).join('')}
        </tbody>
      </table>
    `}
  </div>
</div>

<div class="card" style="padding:0; overflow-x:auto;">
  <div style="padding:16px 20px;" class="flex-between">
    <h2 style="margin:0;">Weekly Reports</h2>
  </div>
  <table>
    <thead>
      <tr>
        <th>Week</th>
        <th>Active</th>
        <th>Referred</th>
        <th>Sold USD</th>
        <th>NET SC</th>
        <th>Net</th>
        <th>Rate</th>
        <th>Commission</th>
        <th>Carryover</th>
        <th>Status</th>
        <th>Sent</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      ${reports.length === 0 ? '<tr><td colspan="12" style="text-align:center;color:#888;padding:20px;">No reports yet.</td></tr>' : ''}
      ${reports.map(r => `
        <tr>
          <td><a href="/report/${r.id}/send">${r.week_label}</a><br><span class="text-gray" style="font-size:11px;">${r.week_range}</span></td>
          <td>${r.active_players}</td>
          <td>${r.referred_players || 0}</td>
          <td>${formatCurrency(r.sold_usd)}</td>
          <td>${formatCurrency(r.net_sc)}</td>
          <td class="${r.net < 0 ? 'text-red' : ''}">${formatCurrency(r.net)}</td>
          <td>${Math.round(r.commission_rate * 100)}%</td>
          <td class="text-green">${formatCurrency(r.total_commission)}</td>
          <td class="${r.carryover_out < 0 ? 'text-red' : ''}">${formatCurrency(r.carryover_out)}</td>
          <td>
            <span class="badge ${r.status === 'paid' ? 'badge-paid' : 'badge-pending'}"
              style="cursor:pointer"
              onclick="toggleStatus(${r.id}, '${r.status === 'paid' ? 'pending' : 'paid'}')">
              ${r.status === 'paid' ? 'Paid' : 'Pending Review'}
            </span>
          </td>
          <td>${r.sent_via_telegram ? '<span class="text-green">\u2713</span>' : '\u2014'}</td>
          <td>
            <div class="flex gap-2">
              <a href="/report/${r.id}/edit" class="btn btn-outline btn-sm">Edit</a>
              <a href="/report/${r.id}/pdf" class="btn btn-outline btn-sm">PDF</a>
              <a href="/report/${r.id}/send" class="btn btn-outline btn-sm">View</a>
              <form method="POST" action="/report/${r.id}/delete" style="display:inline" onsubmit="return confirm('Delete this report?')">
                <button type="submit" class="btn btn-red btn-sm">\u2717</button>
              </form>
            </div>
          </td>
        </tr>
      `).join('')}
    </tbody>
  </table>
</div>

<script>
function toggleStatus(id, newStatus) {
  fetch('/report/' + id + '/status', {
    method: 'POST',
    headers: {'Content-Type': 'application/json'},
    body: JSON.stringify({status: newStatus})
  }).then(function() { location.reload(); });
}
</script>
` }) %>
