<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>PlaySlotsMobile Commissions</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: #0a0a12;
      color: #ffffff;
      min-height: 100vh;
    }
    a { color: #7B4FFF; text-decoration: none; }
    a:hover { text-decoration: underline; color: #9b7aff; }
    .container { max-width: 1100px; margin: 0 auto; padding: 20px; }
    nav {
      background: #0a0a12;
      border-bottom: 2px solid #7B4FFF;
      padding: 10px 20px;
      display: flex;
      align-items: center;
      gap: 24px;
    }
    nav .logo { display: flex; align-items: center; gap: 10px; margin-right: 8px; }
    nav .logo img { height: 48px; width: auto; }
    nav a { color: #aaa; font-size: 14px; }
    nav a:hover { color: #7B4FFF; text-decoration: none; }
    .card {
      background: #12121f;
      border: 1px solid #1a1a2e;
      border-radius: 8px;
      padding: 20px;
      margin-bottom: 16px;
    }
    .card h2 { color: #7B4FFF; margin-bottom: 12px; font-size: 16px; }
    table { width: 100%; border-collapse: collapse; }
    th, td { padding: 10px 12px; text-align: left; border-bottom: 1px solid #1a1a2e; font-size: 13px; }
    th { color: #7B4FFF; font-weight: 600; font-size: 11px; text-transform: uppercase; letter-spacing: 0.5px; }
    tr:hover { background: #1a1a2e; }
    .btn {
      display: inline-block;
      padding: 8px 16px;
      border: none;
      border-radius: 6px;
      cursor: pointer;
      font-size: 13px;
      font-weight: 600;
      text-decoration: none;
      transition: opacity 0.2s;
    }
    .btn:hover { opacity: 0.85; text-decoration: none; }
    .btn-gold { background: #7B4FFF; color: #ffffff; }
    .btn-green { background: #00D4C8; color: #0a0a12; }
    .btn-red { background: #ff6b6b; color: #fff; }
    .btn-outline { background: transparent; border: 1px solid #7B4FFF; color: #7B4FFF; }
    .btn-sm { padding: 4px 10px; font-size: 11px; }
    input, select, textarea {
      background: #1a1a2e;
      border: 1px solid #2a2a4a;
      color: #ffffff;
      padding: 8px 12px;
      border-radius: 6px;
      font-size: 13px;
      width: 100%;
    }
    input:focus, select:focus, textarea:focus {
      outline: none;
      border-color: #7B4FFF;
    }
    label { display: block; margin-bottom: 4px; font-size: 12px; color: #aaa; font-weight: 600; }
    .form-group { margin-bottom: 14px; }
    .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
    .grid-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 14px; }
    .badge {
      display: inline-block;
      padding: 2px 8px;
      border-radius: 10px;
      font-size: 11px;
      font-weight: 600;
    }
    .badge-paid { background: #00D4C8; color: #0a0a12; }
    .badge-unpaid { background: #ff6b6b; color: #fff; }
    .badge-na { background: #555; color: #aaa; }
    .text-gold { color: #7B4FFF; }
    .text-green { color: #00D4C8; }
    .text-red { color: #ff6b6b; }
    .text-gray { color: #888; }
    .text-right { text-align: right; }
    .mb-2 { margin-bottom: 8px; }
    .mb-4 { margin-bottom: 16px; }
    .mt-4 { margin-top: 16px; }
    .flex { display: flex; }
    .flex-between { display: flex; justify-content: space-between; align-items: center; }
    .gap-2 { gap: 8px; }
    .alert {
      padding: 12px 16px;
      border-radius: 6px;
      margin-bottom: 16px;
      font-size: 13px;
    }
    .alert-error { background: #3a1a1a; border: 1px solid #ff6b6b; color: #ff6b6b; }
    .alert-success { background: #0a2a2a; border: 1px solid #00D4C8; color: #00D4C8; }
    .preview-box {
      background: #0a0a12;
      border: 1px solid #1a1a2e;
      border-radius: 8px;
      padding: 20px;
      font-family: monospace;
      font-size: 13px;
      white-space: pre-wrap;
      line-height: 1.6;
    }
    .section-header {
      background: #7B4FFF;
      padding: 6px 12px;
      border-radius: 4px;
      color: #ffffff;
      font-weight: 700;
      font-size: 12px;
      margin: 12px 0 8px 0;
    }
    .calc-row {
      display: flex;
      justify-content: space-between;
      padding: 4px 0;
      font-size: 13px;
    }
    .calc-row .label { color: #aaa; }
    .calc-row .value { font-weight: 600; }
    .tier-table td, .tier-table th { font-size: 12px; padding: 6px 10px; }
    .tier-active { background: #2a1f5c !important; }
    .tier-check { color: #00D4C8; }
    .tier-miss { color: #ff6b6b; }
  </style>
</head>
<body>
  <nav>
    <a href="/" class="logo">
      <img src="/images/logo.png" alt="PlaySlotsMobile">
    </a>
    <a href="/">Dashboard</a>
    <a href="/report/new">New Report</a>
  </nav>
  <div class="container">
    <%- body %>
  </div>
</body>
</html>
